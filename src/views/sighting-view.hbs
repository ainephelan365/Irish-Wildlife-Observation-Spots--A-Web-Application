{{> menu}}

<form class="box"  action="/sighting/{{spot._id}}/updatesighting/{{sighting._id}}" method="POST">
  <label>Update sighting Details:</label>
  <div class="field is-horizontal">
    <div class="field-body">
      <div class="field">
        <input class="input" type="text" name="title", value="{{sighting.title}}">
      </div>
      <div class="field">
        <input class="input" type="text" name="artist" value="{{sighting.artist}}">
      </div>
      <div class="field">
        <input class="input" type="text"  name="duration" value="{{sighting.duration}}">
      </div>
    </div>
  </div>
  <button class="button is-primary">Update sighting</button>
</form>

