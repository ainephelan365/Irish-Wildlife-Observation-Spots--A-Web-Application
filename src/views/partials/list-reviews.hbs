{{#each reviews}}

<div class="" box>

    <h3 class="title is-5">{{title}}</h3>

    <p class="mb-3">{{comment}}</p>
    <p>{{rating}} out of 5</p>
    <span class="tag is-info">Category:{{category}}</span>

</div>


<a href="/spot/{{../spot._id}}/deletereview/{{_id}}" class="button is-danger">
Delete Review</a>
   

    {{/each}}