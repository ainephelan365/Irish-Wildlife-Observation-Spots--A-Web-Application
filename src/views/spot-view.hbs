{{> menu}}


<section class="section">
<section class="section">
  <div class="title">
    {{spot.title}}
  </div>

  <h2 class="title is-4"> Wildlife Sightings Page</h2>
  {{> list-sightings sightings=spot.sightings}}
  {{> add-sighting spotId=spot._id}}


  <h2 class="title is-4"> Wildlife Spot Reviews</h2>
  {{> list-reviews reviews=spot.reviews}}
  {{> add-review spot=spot}}

  <button class="button is-info" onclick="shareWildSpot()">
    Share Wildlife Spot with friends!
  </button>
  
  <br>

  <h2 class="title is-4">Wildlife Spot Gallery: Images from this spot</h2>

  <div class="column">
    {{> spot-image}}
  </div>

</section>

<script>
function shareWildSpot()
{
  const spotLink = window.location.href;
  window.prompt("Wildlife Spot Link:", spotLink);
}
</script>






